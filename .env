# Flask Secret Key (generate a random string for production)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Database URL (SQLite for simplicity)
DATABASE_URL=sqlite:///bsocio.db

# Email Configuration (SMTP)
# For testing, you can use Mailtrap (free tier) or Gmail SMTP
# Please provide your SMTP credentials to replace these placeholders
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@bsocio.in

# Frontend URL for verification links
FRONTEND_URL=http://localhost:5000
