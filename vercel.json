{
  "version": 2,
  "builds": [
    {
      "src": "web/backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "web/backend/app.py"
    }
  ],
  "functions": {
    "web/backend/app.py": {
      "includeFiles": [
        "web/backend/**",
        "src/**",
        "models/**",
        "data/**",
        "web/frontend/**"
      ]
    }
  }
}
