# Flask Secret Key (generate a random string for production)
SECRET_KEY=

# Database URL (SQLite for simplicity)
DATABASE_URL=sqlite:///bsocio.db

# Email Configuration (SMTP)
# For testing, you can use Mailtrap (free tier) or Gmail SMTP
MAIL_SERVER=
MAIL_PORT=
MAIL_USE_TLS=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Frontend URL for verification links
FRONTEND_URL=http://localhost:5000
